{
  "name": "cnsl",
  "version": "2.27.0",
  "description": "![GitHub Pages](https://img.shields.io/badge/hosted%20on-GitHub%20Pages-121013?logo=github&logoColor=white&style=flat-square)\r ![PWA Ready](https://img.shields.io/badge/PWA-ready-0abf53?logo=googlechrome&logoColor=white&style=flat-square)\r ![License](https://img.shields.io/badge/license-MIT-blue.svg?style=flat-square)",
  "main": "service-worker.js",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('out', { recursive: true, force: true })\"",
    "build": "pnpm run clean && node posthtml.js",
    "watch": "nodemon",
    "serve": "http-server ./out -p 3100 -c-1 -o",
    "serve-only": "http-server ./out -p 3100 -c-1",
    "serve-live": "browser-sync start --config browser-sync.config.js",
    "dev": "pnpm run build && pnpm run serve",
    "dev:watch": "concurrently \"pnpm run watch\" \"pnpm run serve-live\"",
    "start": "pnpm run clean && pnpm run dev:watch",
    "start:simple": "pnpm run dev",
    "test": "node --test tests/helpers/*.test.js tests/services/*.test.js tests/models/*.test.js tests/managers/*.test.js tests/types/*.test.js",
    "test:coverage": "node --experimental-test-coverage --test-concurrency=1 --test-coverage-lines=100 --test-coverage-functions=100 --test-coverage-branches=100 --test-coverage-include=src/js/** --test-coverage-include=service-worker.js --test-coverage-exclude=scripts/** --test tests/helpers/*.test.js tests/services/*.test.js tests/models/*.test.js tests/managers/*.test.js tests/types/*.test.js",
    "test:browser:complete": "node scripts/run-playwright.js test",
    "capture:meet-guidance": "node tests/helpers/capture-meet-guidance.js",
    "check:data-updates": "node scripts/season-data-agent.js --season-only --report",
    "extract:pdf": "node scripts/extract-pdf-text.js",
    "validate:data": "node scripts/validate-season-data.js && node scripts/validate-lessons-data.js",
    "verify:pwa": "node scripts/verify-pwa-build.js",
    "measure:performance": "pnpm run build && node scripts/measure-performance.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/simonua/cnsl.git"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "engines": {
    "node": ">=24"
  },
  "bugs": {
    "url": "https://github.com/simonua/cnsl/issues"
  },
  "homepage": "https://pools.longreachmarlins.org/",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "acorn": "^8.17.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "browser-sync": "^3.0.4",
    "concurrently": "^10.0.3",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.14",
    "pdftotext-wasm": "0.1.0",
    "posthtml": "^0.16.7",
    "posthtml-expressions": "^1.11.4",
    "posthtml-extend": "^0.6.5"
  }
}
