{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://example.com/pools.schema.json",
    "version": "V17",
    "title": "Pool Data Schema",
    "description": "Schema for pool data containing schedules, features, and location information",
    "type": "object",
    "properties": {
        "$schema": {
            "type": "string",
            "description": "JSON Schema reference"
        },
        "seasonStartDate": {
            "type": "string",
            "format": "date",
            "description": "Start date of the outdoor pool season"
        },
        "seasonEndDate": {
            "type": "string",
            "format": "date",
            "description": "End date of the outdoor pool season"
        },
        "caPoolDirectoryUrl": {
            "$ref": "#/definitions/HttpsUrl",
            "description": "URL to the Columbia Association online pool directory"
        },
        "caPoolGuideUrl": {
            "$ref": "#/definitions/HttpsUrl",
            "description": "URL to the Columbia Association pool season guide"
        },
        "pools": {
            "type": "array",
            "items": {
                "$ref": "#/definitions/Pool"
            },
            "minItems": 1
        }
    },
    "required": [
        "seasonStartDate",
        "seasonEndDate",
        "caPoolDirectoryUrl",
        "caPoolGuideUrl",
        "pools"
    ],
    "additionalProperties": false,
    "definitions": {
        "Pool": {
            "type": "object",
            "properties": {
                "id": {
                    "$ref": "#/definitions/NonEmptyString"
                },
                "name": {
                    "$ref": "#/definitions/NonEmptyString"
                },
                "caUrl": {
                    "$ref": "#/definitions/HttpsUrl"
                },
                "location": {
                    "$ref": "#/definitions/Location"
                },
                "features": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/FeatureType"
                    },
                    "uniqueItems": true
                },
                "featureOverrides": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/FeatureOverride"
                    },
                    "uniqueItems": true
                },
                "laneCount": {
                    "type": "integer",
                    "minimum": 1,
                    "description": "Number of lanes in the pool"
                },
                "laneLengthUnits": {
                    "enum": [
                        "meters",
                        "yards",
                        null
                    ],
                    "description": "Lane measurement unit, when published"
                },
                "laneLength": {
                    "type": ["number", "null"],
                    "exclusiveMinimum": 0,
                    "description": "Lane length in laneLengthUnits, when published"
                },
                "schedules": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/Schedule"
                    }
                },
                "scheduleOverrides": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/ScheduleOverride"
                    }
                },
                "scheduleUrl": {
                    "$ref": "#/definitions/HttpsUrl"
                },
                "phone": {
                    "type": "string",
                    "pattern": "^[0-9]{3}-[0-9]{3}-[0-9]{4}$",
                    "description": "Pool desk phone number in format XXX-XXX-XXXX"
                }
            },
            "required": [
                "id",
                "name",
                "caUrl",
                "location",
                "features",
                "laneCount",
                "laneLengthUnits",
                "laneLength",
                "scheduleUrl",
                "schedules"
            ],
            "additionalProperties": false
        },
        "Schedule": {
            "type": "object",
            "properties": {
                "startDate": {
                    "type": "string",
                    "format": "date"
                },
                "endDate": {
                    "type": "string",
                    "format": "date"
                },
                "hours": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/Hours"
                    },
                    "minItems": 1
                }
            },
            "required": [
                "startDate",
                "endDate",
                "hours"
            ],
            "additionalProperties": false
        },
        "ScheduleOverride": {
            "type": "object",
            "properties": {
                "startDate": {
                    "type": "string",
                    "format": "date"
                },
                "endDate": {
                    "type": "string",
                    "format": "date"
                },
                "hours": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/Hours"
                    },
                    "minItems": 1
                },
                "overrideMode": {
                    "$ref": "#/definitions/ScheduleOverrideMode",
                    "description": "Whether the dated hours overlay recurring intervals or replace the complete regular day"
                },
                "reason": {
                    "type": "string",
                    "minLength": 1,
                    "description": "Free form string describing the reason for the schedule override"
                }
            },
            "required": [
                "startDate",
                "endDate",
                "hours",
                "reason"
            ],
            "additionalProperties": false
        },
        "Hours": {
            "type": "object",
            "allOf": [
                {
                    "$ref": "#/definitions/ScheduleActivityClassification"
                },
                {
                    "$ref": "#/definitions/ScheduleHoursTimeContract"
                }
            ],
            "properties": {
                "weekDays": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/WeekDayType"
                    },
                    "minItems": 1,
                    "uniqueItems": true
                },
                "startTime": {
                    "$ref": "#/definitions/TimeType"
                },
                "endTime": {
                    "$ref": "#/definitions/TimeType"
                },
                "types": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/ScheduleType"
                    },
                    "minItems": 1,
                    "uniqueItems": true
                },
                "accessStatus": {
                    "$ref": "#/definitions/AccessStatusType",
                    "description": "Semantic public-access status used for live pool availability and indicators"
                },
                "notes": {
                    "type": "string"
                },
                "sourceUrl": {
                    "$ref": "#/definitions/HttpsUrl",
                    "description": "Official source URL for details about this scheduled activity"
                }
            },
            "required": [
                "weekDays",
                "types",
                "accessStatus"
            ],
            "additionalProperties": false
        },
        "ScheduleActivityClassification": {
            "oneOf": [
                {
                    "properties": {
                        "types": {
                            "$ref": "#/definitions/PublicScheduleActivity"
                        },
                        "accessStatus": {
                            "const": "public"
                        }
                    }
                },
                {
                    "properties": {
                        "types": {
                            "$ref": "#/definitions/RestrictedScheduleActivity"
                        },
                        "accessStatus": {
                            "const": "restricted"
                        }
                    }
                },
                {
                    "properties": {
                        "types": {
                            "$ref": "#/definitions/PracticeScheduleActivity"
                        },
                        "accessStatus": {
                            "const": "practice-only"
                        }
                    }
                },
                {
                    "properties": {
                        "types": {
                            "$ref": "#/definitions/ClosedScheduleActivity"
                        },
                        "accessStatus": {
                            "const": "closed-to-public"
                        }
                    }
                },
                {
                    "properties": {
                        "types": {
                            "$ref": "#/definitions/SpecialEventScheduleActivity"
                        },
                        "accessStatus": {
                            "const": "special-event"
                        }
                    }
                },
                {
                    "properties": {
                        "types": {
                            "$ref": "#/definitions/SwimMeetScheduleActivity"
                        },
                        "accessStatus": {
                            "const": "swim-meet"
                        }
                    }
                }
            ]
        },
        "PublicScheduleActivity": {
            "type": "array",
            "enum": [
                ["Adult Laps Only"],
                ["Adult Swim"],
                ["Laps"],
                ["Rec Swim"],
                ["Senior Swim"],
                ["Ultimate Rec Swim"],
                ["Wading Pool"],
                ["Wibit"],
                ["Laps", "Rec Swim"],
                ["Lessons", "Rec Swim"],
                ["Lessons", "Wading Pool"],
                ["Masters Swim", "Adult Laps Only"],
                ["Laps", "Rec Swim", "CNSL Practice Only"]
            ]
        },
        "RestrictedScheduleActivity": {
            "type": "array",
            "enum": [
                ["Aqua Fitness"],
                ["Combo Fitness"],
                ["Lessons"],
                ["Masters Swim"],
                ["Yoga"]
            ]
        },
        "PracticeScheduleActivity": {
            "type": "array",
            "enum": [
                ["Clippers Practice Only"],
                ["CNSL Practice Only"]
            ]
        },
        "ClosedScheduleActivity": {
            "type": "array",
            "enum": [
                ["Closed"],
                ["Closed to Public"]
            ]
        },
        "SpecialEventScheduleActivity": {
            "type": "array",
            "enum": [
                ["Pool Party"],
                ["Special Event"]
            ]
        },
        "SwimMeetScheduleActivity": {
            "const": ["Swim Meet"]
        },
        "ScheduleHoursTimeContract": {
            "if": {
                "properties": {
                    "accessStatus": {
                        "const": "closed-to-public"
                    }
                }
            },
            "then": {
                "oneOf": [
                    {
                        "required": ["startTime", "endTime"]
                    },
                    {
                        "not": {
                            "anyOf": [
                                {
                                    "required": ["startTime"]
                                },
                                {
                                    "required": ["endTime"]
                                }
                            ]
                        }
                    }
                ]
            },
            "else": {
                "required": ["startTime", "endTime"]
            }
        },
        "NonEmptyString": {
            "type": "string",
            "minLength": 1
        },
        "HttpsUrl": {
            "type": "string",
            "format": "uri",
            "pattern": "^https://"
        },
        "Location": {
            "type": "object",
            "properties": {
                "street": {
                    "$ref": "#/definitions/NonEmptyString"
                },
                "city": {
                    "$ref": "#/definitions/NonEmptyString"
                },
                "state": {
                    "$ref": "#/definitions/NonEmptyString"
                },
                "zip": {
                    "type": "string",
                    "pattern": "^[0-9]{5}(-[0-9]{4})?$"
                },
                "lat": {
                    "$ref": "#/definitions/Latitude"
                },
                "lng": {
                    "$ref": "#/definitions/Longitude"
                },
                "mapsQuery": {
                    "$ref": "#/definitions/NonEmptyString"
                },
                "googleMapsUrl": {
                    "$ref": "#/definitions/HttpsUrl",
                    "description": "Direct Google Maps URL for the pool location. Format: https://www.google.com/maps/search/?api=1&query=ENCODED_ADDRESS"
                }
            },
            "required": [
                "street",
                "city",
                "state",
                "zip",
                "lat",
                "lng",
                "mapsQuery",
                "googleMapsUrl"
            ],
            "additionalProperties": false
        },
        "Latitude": {
            "type": "number",
            "minimum": -90,
            "maximum": 90
        },
        "Longitude": {
            "type": "number",
            "minimum": -180,
            "maximum": 180
        },
        "FeatureType": {
            "type": "string",
            "enum": [
                "ADA compliant",
                "baseball",
                "basketball court",
                "bathhouse",
                "climbing wall",
                "cornhole",
                "deck",
                "diving board",
                "diving well",
                "family changing room",
                "fitness pavilion",
                "golf course",
                "grass volleyball",
                "grill",
                "heated pool",
                "hot tub",
                "in-water basketball",
                "lap",
                "lessons",
                "main pool beach entry",
                "main pool slide",
                "main pool water features",
                "party area",
                "picnic area",
                "pool lift",
                "sand volleyball",
                "sensory friendly",
                "shade",
                "shallow",
                "soccer",
                "softball",
                "splash",
                "sports field",
                "tennis",
                "tot lot",
                "wading",
                "wading pool beach entry",
                "wading pool slide",
                "wading pool water features",
                "wifi",
                "yoga"
            ]
        },
        "FeatureOverride": {
            "type": "object",
            "properties": {
                "feature": {
                    "$ref": "#/definitions/FeatureType"
                },
                "action": {
                    "enum": [
                        "add",
                        "remove"
                    ]
                },
                "evidence": {
                    "$ref": "#/definitions/FeatureOverrideEvidence"
                }
            },
            "required": [
                "feature",
                "action",
                "evidence"
            ],
            "additionalProperties": false
        },
        "FeatureOverrideEvidence": {
            "type": "object",
            "properties": {
                "type": {
                    "enum": [
                        "maintainer",
                        "official-source"
                    ]
                },
                "observedOn": {
                    "type": "string",
                    "format": "date"
                },
                "officialSourceCheckedOn": {
                    "type": "string",
                    "format": "date"
                },
                "sourceUrl": {
                    "$ref": "#/definitions/HttpsUrl"
                },
                "note": {
                    "$ref": "#/definitions/NonEmptyString"
                }
            },
            "required": [
                "type",
                "officialSourceCheckedOn",
                "note"
            ],
            "allOf": [
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "maintainer"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "observedOn"
                        ]
                    }
                },
                {
                    "if": {
                        "properties": {
                            "type": {
                                "const": "official-source"
                            }
                        }
                    },
                    "then": {
                        "required": [
                            "sourceUrl"
                        ]
                    }
                }
            ],
            "additionalProperties": false
        },
        "WeekDayType": {
            "type": "string",
            "enum": [
                "Mon",
                "Tue",
                "Wed",
                "Thu",
                "Fri",
                "Sat",
                "Sun"
            ]
        },
        "AccessStatusType": {
            "type": "string",
            "enum": [
                "closed-to-public",
                "practice-only",
                "public",
                "restricted",
                "special-event",
                "swim-meet"
            ]
        },
        "ScheduleOverrideMode": {
            "type": "string",
            "enum": [
                "overlay",
                "replace-day"
            ]
        },
        "ScheduleType": {
            "type": "string",
            "enum": [
                "Adult Laps Only",
                "Adult Swim",
                "Aqua Fitness",
                "Clippers Practice Only",
                "Closed",
                "Closed to Public",
                "Combo Fitness",
                "CNSL Practice Only",
                "Laps",
                "Lessons",
                "Masters Swim",
                "Pool Party",
                "Rec Swim",
                "Senior Swim",
                "Special Event",
                "Swim Meet",
                "Ultimate Rec Swim",
                "Wibit",
                "Wading Pool",
                "Yoga"
            ]
        },
        "TimeType": {
            "type": "string",
            "pattern": "^(0?[1-9]|1[0-2]):[0-5][0-9](AM|PM|am|pm)$"
        }
    }
}
