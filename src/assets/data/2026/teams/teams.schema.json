{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/teams.schema.json",
  "version": "V16",
  "title": "Team Data Schema",
  "description": "Schema for team data containing practice schedules and team information",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "teams": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/Team"
      },
      "minItems": 1
    }
  },
  "required": ["teams"],
  "additionalProperties": false,
  "definitions": {
    "Team": {
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "shortName": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "keywords": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NonEmptyString"
          },
          "minItems": 1
        },
        "url": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "resultsUrl": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "calendarUrl": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "eventsSubscriptionUrl": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            }
          ]
        },
        "merchandiseUrl": {
          "anyOf": [
            {
              "const": ""
            },
            {
              "type": "string",
              "format": "uri",
              "pattern": "^https://"
            }
          ]
        },
        "booster": {
          "$ref": "#/definitions/Booster"
        },
        "homePools": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NonEmptyString"
          },
          "minItems": 1
        },
        "timeTrialsPool": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "meetTimeOverrides": {
          "$ref": "#/definitions/MeetTimeOverrides"
        },
        "homeMeetGuides": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HomeMeetGuide"
          },
          "minItems": 1
        },
        "practicePools": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NonEmptyString"
          },
          "minItems": 1
        },
        "staff": {
          "$ref": "#/definitions/TeamStaff"
        },
        "practice": {
          "$ref": "#/definitions/DetailedPractice"
        }
      },
      "required": ["id", "name", "shortName", "keywords", "url", "merchandiseUrl", "eventsSubscriptionUrl", "homePools", "timeTrialsPool", "practicePools", "staff"],
      "additionalProperties": false
    },
    "HomeMeetGuide": {
      "type": "object",
      "properties": {
        "poolId": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "source": {
          "$ref": "#/definitions/HomeMeetGuideSource"
        },
        "general": {
          "$ref": "#/definitions/HomeMeetGeneralGuide"
        },
        "homeTeam": {
          "anyOf": [
            { "$ref": "#/definitions/HomeTeamMeetGuide" },
            { "type": "null" }
          ]
        },
        "visitingTeam": {
          "anyOf": [
            { "$ref": "#/definitions/VisitingTeamMeetGuide" },
            { "type": "null" }
          ]
        }
      },
      "required": ["poolId", "source", "homeTeam", "visitingTeam"],
      "anyOf": [
        { "required": ["general"] },
        { "properties": { "homeTeam": { "$ref": "#/definitions/HomeTeamMeetGuide" } } },
        { "properties": { "visitingTeam": { "$ref": "#/definitions/VisitingTeamMeetGuide" } } }
      ],
      "additionalProperties": false
    },
    "HomeMeetGuideSource": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["host-team-manager", "visiting-team-manager"]
        },
        "receivedOn": {
          "type": "string",
          "format": "date"
        }
      },
      "required": ["type", "receivedOn"],
      "additionalProperties": false
    },
    "HomeMeetGeneralGuide": {
      "type": "object",
      "properties": {
        "parkingLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "parkingNotes": {
          "$ref": "#/definitions/NonEmptyStringArray"
        },
        "poolsideConditions": {
          "$ref": "#/definitions/NonEmptyStringArray"
        },
        "helpfulNotes": {
          "$ref": "#/definitions/NonEmptyStringArray"
        },
        "concessions": {
          "$ref": "#/definitions/HomeMeetConcessions"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "HomeTeamMeetGuide": {
      "type": "object",
      "properties": {
        "arrivalTime": {
          "$ref": "#/definitions/ClockTime"
        },
        "arrivalGuidance": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "parkingLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "familySetupLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "clerkGuidance": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "checkInGuidance": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "volunteerCheckInLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "swimmerCheckInLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "warmupTime": {
          "$ref": "#/definitions/ClockTime"
        },
        "helpfulNotes": {
          "$ref": "#/definitions/NonEmptyStringArray"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "VisitingTeamMeetGuide": {
      "type": "object",
      "properties": {
        "arrivalTime": {
          "$ref": "#/definitions/ClockTime"
        },
        "arrivalGuidance": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "reservedParking": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "familySetupLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "clerkGuidance": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "checkInGuidance": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "swimmerCheckInLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "volunteerCheckInLocation": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "warmupTime": {
          "$ref": "#/definitions/ClockTime"
        },
        "helpfulNotes": {
          "$ref": "#/definitions/NonEmptyStringArray"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "HomeMeetConcessions": {
      "type": "object",
      "properties": {
        "opensAt": {
          "$ref": "#/definitions/ClockTime"
        },
        "paymentMethods": {
          "type": "array",
          "items": {
            "enum": ["cash", "credit", "venmo", "paypal", "other"]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "smallBillsPreferred": {
          "type": "boolean"
        },
        "denominationsNotAccepted": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "foodItems": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NonEmptyString"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "mealItems": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NonEmptyString"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "snackItems": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NonEmptyString"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "drinkItems": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/NonEmptyString"
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "dietaryOptions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/HomeMeetDietaryOption"
          },
          "uniqueItems": true
        },
        "notes": {
          "$ref": "#/definitions/NonEmptyStringArray"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "HomeMeetDietaryOption": {
      "type": "object",
      "properties": {
        "type": {
          "enum": ["allergy-friendly", "gluten-free", "other", "vegan", "vegetarian"]
        },
        "availability": {
          "enum": ["available", "by-request", "limited"]
        }
      },
      "required": ["type", "availability"],
      "additionalProperties": false
    },
    "NonEmptyStringArray": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/NonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "MeetTimeOverrides": {
      "type": "object",
      "properties": {
        "dualMeets": {
          "$ref": "#/definitions/TimingWindow"
        },
        "timeTrials": {
          "$ref": "#/definitions/TimingWindow"
        }
      },
      "minProperties": 1,
      "additionalProperties": false
    },
    "TimingWindow": {
      "type": "object",
      "properties": {
        "start": {
          "$ref": "#/definitions/ClockTime"
        },
        "end": {
          "$ref": "#/definitions/ClockTime"
        }
      },
      "required": ["start", "end"],
      "additionalProperties": false
    },
    "ClockTime": {
      "type": "string",
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
    },
    "Booster": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "url": {
          "type": "string",
          "format": "uri",
          "pattern": "^https://"
        }
      },
      "required": ["name", "url"],
      "additionalProperties": false
    },
    "TeamStaff": {
      "type": "object",
      "properties": {
        "sourceUrl": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "verifiedOn": {
          "type": "string",
          "format": "date"
        },
        "coaches": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StaffMember"
          }
        },
        "managers": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StaffMember"
          }
        },
        "contacts": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/StaffContact"
          }
        },
        "note": {
          "$ref": "#/definitions/NonEmptyString"
        }
      },
      "required": ["sourceUrl", "verifiedOn", "coaches", "managers", "contacts"],
      "additionalProperties": false
    },
    "StaffMember": {
      "type": "object",
      "properties": {
        "name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "role": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "email": {
          "$ref": "#/definitions/EmailAddress"
        }
      },
      "required": ["name", "role"],
      "additionalProperties": false
    },
    "StaffContact": {
      "type": "object",
      "properties": {
        "audience": {
          "type": "string",
          "enum": ["coaches", "managers"]
        },
        "label": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "email": {
          "$ref": "#/definitions/EmailAddress"
        }
      },
      "required": ["audience", "label", "email"],
      "additionalProperties": false
    },
    "DetailedPractice": {
      "type": "object",
      "properties": {
        "url": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "preseason": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/PreseasonPractice"
          }
        },
        "regular": {
          "$ref": "#/definitions/RegularPractice"
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/SimplePracticeSession"
          }
        }
      },
      "required": ["url"],
      "additionalProperties": false
    },
    "PreseasonPractice": {
      "type": "object",
      "properties": {
        "period": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "days": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "location": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "address": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Session"
          },
          "minItems": 1
        }
      },
      "required": ["period", "days", "location", "sessions"],
      "additionalProperties": false
    },
    "RegularPractice": {
      "type": "object",
      "properties": {
        "season": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "morning": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/MorningPractice"
          },
          "minItems": 1
        },
        "evening": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/EveningPractice"
          },
          "minItems": 1
        }
      },
      "required": ["season", "morning", "evening"],
      "additionalProperties": false
    },
    "MorningPractice": {
      "type": "object",
      "properties": {
        "days": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "location": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "address": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Session"
          },
          "minItems": 1
        }
      },
      "required": ["days", "location", "sessions"],
      "additionalProperties": false
    },
    "EveningPractice": {
      "type": "object",
      "properties": {
        "day": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "location": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "address": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "sessions": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/Session"
          },
          "minItems": 1
        }
      },
      "required": ["day", "location", "sessions"],
      "additionalProperties": false
    },
    "Session": {
      "type": "object",
      "properties": {
        "time": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "group": {
          "$ref": "#/definitions/NonEmptyString"
        }
      },
      "required": ["time", "group"],
      "additionalProperties": false
    },
    "SimplePracticeSession": {
      "type": "object",
      "properties": {
        "day": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "time": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "location": {
          "$ref": "#/definitions/NonEmptyString"
        }
      },
      "required": ["day", "time", "location"],
      "additionalProperties": false
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "EmailAddress": {
      "type": "string",
      "format": "email",
      "minLength": 3
    }
  }
}
