{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/meets.schema.json",
  "version": "V4",
  "title": "Meet Data Schema",
  "description": "Schema for meet data containing regular and special meets",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema reference"
    },
    "url": {
      "$ref": "#/definitions/HttpsUrl"
    },
    "meetTimes": {
      "$ref": "#/definitions/StandardMeetTimes"
    },
    "regular_meets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/RegularMeet"
      }
    },
    "special_meets": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/SpecialMeet"
      }
    }
  },
  "required": ["url", "meetTimes", "regular_meets", "special_meets"],
  "additionalProperties": false,
  "definitions": {
    "RegularMeet": {
      "type": "object",
      "properties": {
        "date": {
          "$ref": "#/definitions/DateFormat"
        },
        "name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "visiting_team": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "home_team": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "location": {
          "$ref": "#/definitions/NonEmptyString"
        }
      },
      "required": ["date", "visiting_team", "home_team", "location"],
      "additionalProperties": false
    },
    "SpecialMeet": {
      "type": "object",
      "properties": {
        "date": {
          "$ref": "#/definitions/DateFormat"
        },
        "name": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "location": {
          "$ref": "#/definitions/NonEmptyString"
        },
        "timeWindowKey": {
          "const": "timeTrials"
        }
      },
      "required": ["date", "name", "location"],
      "additionalProperties": false
    },
    "StandardMeetTimes": {
      "type": "object",
      "properties": {
        "dualMeets": {
          "$ref": "#/definitions/DualMeetTimingWindow"
        },
        "timeTrials": {
          "$ref": "#/definitions/TimingWindow"
        }
      },
      "required": ["dualMeets", "timeTrials"],
      "additionalProperties": false
    },
    "DualMeetTimingWindow": {
      "type": "object",
      "properties": {
        "start": {
          "$ref": "#/definitions/ClockTime"
        },
        "end": {
          "$ref": "#/definitions/ClockTime"
        },
        "relayCheckInDeadline": {
          "$ref": "#/definitions/ClockTime"
        },
        "firstSwimTime": {
          "$ref": "#/definitions/ClockTime"
        }
      },
      "required": ["start", "end", "relayCheckInDeadline", "firstSwimTime"],
      "additionalProperties": false
    },
    "TimingWindow": {
      "type": "object",
      "properties": {
        "start": {
          "$ref": "#/definitions/ClockTime"
        },
        "end": {
          "$ref": "#/definitions/ClockTime"
        }
      },
      "required": ["start", "end"],
      "additionalProperties": false
    },
    "ClockTime": {
      "type": "string",
      "pattern": "^([01]\\d|2[0-3]):[0-5]\\d$"
    },
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "HttpsUrl": {
      "type": "string",
      "format": "uri",
      "pattern": "^https://"
    },
    "DateFormat": {
      "type": "string",
      "format": "date"
    }
  }
}
